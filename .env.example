# .env is NOT in git (.gitignore). After git pull: copy this file and name it .env:
#   cp .env.example .env
# On Raspberry Pi POC without PostgreSQL, keep TESTING=1 below.
#
# --- Proof-of-concept / testing (local demo, e.g. Raspberry Pi without PostgreSQL) ---
# When TESTING=1: SQLite file poc_maintenance.db (override with TESTING_DATABASE_URL),
# demo devices are auto-seeded, PLC poll is off, synthetic readings + console analysis run.
# This is read from .env by the app (not only os.environ); required for POC on a Pi.
TESTING=1
# Optional: sqlite:///:memory: for ephemeral runs
# TESTING_DATABASE_URL=sqlite:///:memory:

# Ignored while TESTING=1 (app uses TESTING_DATABASE_URL / default SQLite path above).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/maintenance

# PLC (used only when TESTING is unset or not 1)
PLC_HOST=192.168.1.10
PLC_POLL_INTERVAL_SECONDS=10.0
PLC_STATUS_WRITE_ENABLED=true
PLC_CONNECT_TIMEOUT_SECONDS=5.0
PLC_RETRY_ATTEMPTS=3
PLC_RETRY_BASE_DELAY_SECONDS=1.0

# Scheduled analysis + retention (disabled when TESTING=1; set SCHEDULER_ENABLED=0 for pytest)
SCHEDULER_ENABLED=true
# Fractional minutes OK (e.g. 0.08333 ≈ 5 s when TESTING=0 and scheduler runs).
MAINTENANCE_ANALYSIS_INTERVAL_MINUTES=15
SENSOR_READINGS_RETENTION_DAYS=90
RETENTION_BATCH_SIZE=2000
RETENTION_JOB_HOUR_UTC=2
RETENTION_JOB_MINUTE_UTC=30

# Logging (INFO, WARNING, DEBUG)
LOG_LEVEL=INFO

# Synthetic POC timing (TESTING=1)
SYNTHETIC_POLL_INTERVAL_SECONDS=5.0
POC_ANALYSIS_INTERVAL_SECONDS=30.0

# Debug: set true to log SQL
DB_ECHO=false

# Notifications (POC: false keeps console output focused)
NOTIFICATIONS_ENABLED=false

# Email (SMTP). Leave SMTP_HOST empty to disable.
# Example (Gmail): SMTP_HOST=smtp.gmail.com; use an app password for SMTP_PASSWORD.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=

# Optional: always notify this address on recommendation changes (deduped vs API subscribers).
# NOTIFICATION_ALERT_EMAIL=you@example.com
