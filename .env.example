# Database (PostgreSQL). User and password must match a real role on the server.
# Raspberry Pi / Debian: default postgres password is often unset until you set it:
#   sudo -u postgres psql -c "ALTER USER postgres PASSWORD 'your_secret';"
# Or use a dedicated user: CREATE USER capstone WITH PASSWORD '...'; GRANT ...
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/maintenance

# Allen-Bradley CompactLogix (EtherNet/IP). Controller tag names are mapped in plc_tag_map.
PLC_HOST=192.168.1.10
PLC_POLL_INTERVAL_SECONDS=10.0

# Debug: set true to log SQL
DB_ECHO=false

# Notifications
NOTIFICATIONS_ENABLED=true

# Email (SMTP). Leave SMTP_HOST empty to disable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
