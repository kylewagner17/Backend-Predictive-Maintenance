# --- Proof-of-concept / testing (local demo) ---
# When TESTING=1: SQLite file poc_maintenance.db (override with TESTING_DATABASE_URL),
# demo devices are auto-seeded, PLC poll is off, synthetic readings + console analysis run.
TESTING=1
# Optional: sqlite:///:memory: for ephemeral runs
# TESTING_DATABASE_URL=sqlite:///:memory:

# Ignored while TESTING=1 (app uses TESTING_DATABASE_URL / default SQLite path above).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/maintenance

# PLC (used only when TESTING is unset or not 1)
PLC_HOST=192.168.1.10
PLC_POLL_INTERVAL_SECONDS=10.0

# Synthetic POC timing (TESTING=1)
SYNTHETIC_POLL_INTERVAL_SECONDS=5.0
POC_ANALYSIS_INTERVAL_SECONDS=30.0

# Debug: set true to log SQL
DB_ECHO=false

# Notifications (POC: false keeps console output focused)
NOTIFICATIONS_ENABLED=false

# Email (SMTP). Leave SMTP_HOST empty to disable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
